# ════════════════════════════════════════════════════════════
# Brain Bot V13 — Environment Configuration
# Copy this file to .env and fill in your values
# ════════════════════════════════════════════════════════════

# ── Execution Mode ────────────────────────────────────────
# paper    = PaperExecutionEngine (no real orders, DEFAULT)
# testnet  = Binance Futures Testnet (fake money, real API)
# live     = Binance Futures Mainnet ⚠️ REAL MONEY ⚠️
EXECUTION_MODE=paper

# ── Binance Mainnet (data fetch only for paper/testnet) ──
BINANCE_API_KEY=your_mainnet_api_key_here
BINANCE_API_SECRET=your_mainnet_api_secret_here

# ── Binance Testnet (used when EXECUTION_MODE=testnet) ───
# Get keys at: https://testnet.binancefuture.com
BINANCE_TESTNET=true
BINANCE_TESTNET_API_KEY=your_testnet_api_key_here
BINANCE_TESTNET_API_SECRET=your_testnet_api_secret_here

# ── Trading Parameters ────────────────────────────────────
SYMBOL=BTCUSDT
LEVERAGE=5

# ── Risk Management ───────────────────────────────────────
RISK_PER_TRADE_MIN=0.005
RISK_PER_TRADE_MAX=0.01
MAX_DAILY_LOSS=0.03
MAX_CONSECUTIVE_LOSSES=3

# ── Loop Interval (seconds) ───────────────────────────────
LOOP_INTERVAL=60
