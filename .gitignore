# ─── Secrets ───────────────────────────────────────────────
.env
*.env
.env.*
!.env.example

# ─── Python ────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/

# ─── Databases ─────────────────────────────────────────────
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# ─── Logs ──────────────────────────────────────────────────
logs/
*.log

# ─── Testing ───────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# ─── IDE ───────────────────────────────────────────────────
.vscode/
.idea/
*.swp

# ─── Bundle Manager (tools/bundle_manager.py) ─────────────
# The bundle files themselves are transient inbound/outbound artifacts,
# not source — never commit them. bundle_history.json (repo root) IS
# tracked deliberately (shared duplicate-import ledger, not local cache)
# and is NOT excluded here.
update/incoming/*
update/applied/*
update/failed/*
!update/incoming/.gitkeep
!update/applied/.gitkeep
!update/failed/.gitkeep
